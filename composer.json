{
    "name": "ilchcms/ilch-2.0",
    "description": "CMS for Clans and Communities",
    "type": "project",
    "license": "GPLv3",
    "minimum-stability": "stable",
    "config": {
        "platform": {
            "php": "8.1"
        }
    },
    "require": {
        "php": ">=8.1",
        "ifsnop/mysqldump-php": "^2.12",
        "kartik-v/bootstrap-star-rating": "^4.1.2",
        "twbs/bootstrap": "^5.3.8",
        "fortawesome/font-awesome": "^7.2.0",
        "npm-asset/jquery": "^4.0.0",
        "npm-asset/jquery-ui": "^1.14.2",
        "phpmailer/phpmailer": "^7.1.1",
        "ezyang/htmlpurifier": "^4.19"
    },
    "require-dev": {
        "php-debugbar/php-debugbar": "^2.2.6",
        "phpunit/phpunit": "^10.5.63",
        "symfony/yaml": "^6.4.41"
    },
    "autoload": {
        "psr-0": {
            "": "application/libraries/"
        },
        "files": [
            "application/libraries/Ilch/Functions.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "PHPUnit\\": "tests/PHPUnit"
        }
    },
    "repositories": [
        {
            "type": "composer",
            "url": "https://asset-packagist.org"
        }
    ]
}
